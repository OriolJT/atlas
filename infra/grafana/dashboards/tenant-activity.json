{
  "uid": "atlas-tenant-activity",
  "title": "Atlas — Tenant Activity",
  "tags": ["atlas", "tenants"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "label": "Tenant",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(atlas_workflow_execution_started_total, tenant_id)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-Tenant Execution Volume",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(atlas_workflow_execution_started_total{tenant_id=~\"$tenant_id\"}[2m])) by (tenant_id)",
          "legendFormat": "{{ tenant_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API Request Rate per Tenant",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\".*-service\", tenant_id=~\"$tenant_id\"}[2m])) by (tenant_id)",
          "legendFormat": "{{ tenant_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Auth Failure Rate per Tenant",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(atlas_auth_failure_total{tenant_id=~\"$tenant_id\"}[2m])) by (tenant_id)",
          "legendFormat": "{{ tenant_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Top Tenants by Execution Count (1h)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "topk(10, increase(atlas_workflow_execution_started_total[1h])) by (tenant_id)",
          "legendFormat": "{{ tenant_id }}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Tenants",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "count(count by (tenant_id) (rate(atlas_workflow_execution_started_total[5m]) > 0))",
          "legendFormat": "Active tenants",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Auth Failures (1h)",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(increase(atlas_auth_failure_total[1h]))",
          "legendFormat": "Auth failures",
          "refId": "A"
        }
      ]
    }
  ]
}
